# Socket.io server (voice chat signaling). Defaults to the Render deployment
# if unset, so this is optional.
VITE_SOCKET_URL=https://staple-socket-server.onrender.com

# Supabase — copy your project URL and anon key from
# Supabase dashboard → Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# E-posta doğrulama / şifre sıfırlama / Google OAuth dönüş adresinin kökü.
# Boş bırakılırsa window.location.origin kullanılır (dev'de localhost).
# Prod build'de mutlaka doldur: https://web.stapleapp.com
VITE_SITE_URL=

# Klipy GIF Search API Key
VITE_KLIPY_API_KEY=
